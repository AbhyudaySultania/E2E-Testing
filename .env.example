# rx-pad UAT environment
RX_PAD_BASE_URL=https://pm-uat-doctor-portal.tatvacare.in

# UAT JWT — obtain from QA or one manual login session
# Never commit the real value; copy this file to .env and paste your token
RX_PAD_JWT=<PASTE_YOUR_JWT_HERE>

# Patient for walk-in / all patients / appointment navigation (match doctor JWT account)
# RX_PAD_PATIENT_NAME=Abhyuday Sultania Updated ws
# RX_PAD_PATIENT_MOBILE=9821885020
# RX_PAD_PATIENT_SEARCH=9821885020

# Optional: medicine search terms for prescription E2E (defaults: Para, Azithral)
# RX_PAD_MEDICINE_SEARCH=Para
# RX_PAD_MEDICINE_SEARCH_2=Azithral

# Optional: symptom search term for symptoms regression (default: Fever)
# RX_PAD_SYMPTOM_SEARCH=Fever

# Dev speed: single entry path for module regression (walk-in | patient-details | appointment)
# RX_PAD_ENTRY_PATH=walk-in

# Commit check: add a module spec (e.g. vaccination, medications, vitals)
# RX_PAD_COMMIT_MODULE=vaccination

# Vaccination PDF text assert (default: localhost only; set 1 after portal deploy to UAT)
# RX_PAD_ASSERT_VACCINATION_PDF=1

# Doctor-specific custom Diet module (not in standard regression gate)
# Set RX_PAD_CUSTOM_DIET=1 to include diet in full-consultation; run diet tests via npm run test:custom:diet
# RX_PAD_CUSTOM_DIET=1
# RX_PAD_DIET_MODULE_NAME=Diet
# RX_PAD_DIET_TITLE=Protein
# RX_PAD_DIET_NOTES=35 gm at least

# ZeroStep hybrid tests (legacy) — https://zerostep.com
# ZEROSTEP_TOKEN=your-token-here

# Midscene AI scenario runner (tests/ai/scenarios/*.md) — https://midscenejs.com
# OpenAI example (see midscenejs.com/model-strategy for Qwen, Gemini, etc.)
# MIDSCENE_MODEL_BASE_URL=https://api.openai.com/v1
# MIDSCENE_MODEL_API_KEY=sk-...
# MIDSCENE_MODEL_NAME=gpt-4o
# MIDSCENE_MODEL_FAMILY=openai

# AI NL scenario filter — filename without .md
# RX_AI_SCENARIO=walk-in-prescription

# Playwright screenshot timeout in CI when fonts load slowly (optional)
# PW_TEST_SCREENSHOT_NO_FONTS_READY=1
